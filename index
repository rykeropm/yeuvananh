<div class="flower-container"></div>

<script>
const flowers = ["🌼", "🌸", "🌻", "💛", " ❤️"];

function createFlower() {
  const flower = document.createElement("div");
  flower.classList.add("flower");

  flower.innerHTML = flowers[Math.floor(Math.random() * flowers.length)];

  flower.style.left = Math.random() * window.innerWidth + "px";
  flower.style.animationDuration = (10 + Math.random() * 8) + "s";
  flower.style.fontSize = (18 + Math.random() * 30) + "px";
  flower.style.opacity = 0.6 + Math.random() * 0.4;

  document.querySelector(".flower-container").appendChild(flower);

  setTimeout(() => {
    flower.remove();
  }, 18000);
}

setInterval(createFlower, 900);

</script>
<script>
function showPhotos() {
    const photos = document.querySelectorAll(".photo");

    photos.forEach((photo, index) => {

        // chia ảnh trái phải
        if(index % 2 === 0){
            photo.classList.add("left");
        } else {
            photo.classList.add("right");
        }

        setTimeout(() => {
            photo.classList.add("show");
        }, index * 200); // delay từng ảnh
    });
}
</script>
